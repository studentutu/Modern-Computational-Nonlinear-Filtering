@PACKAGE_INIT@

# nlfConfig.cmake — CMake package config for Modern-Computational-Nonlinear-Filtering.
#
# Usage:
#     find_package(nlf REQUIRED)
#     target_link_libraries(my_app PRIVATE nlf::nlf)
#
# nlf::nlf carries both include roots, so either include style works:
#     #include "UKF.h"                  // flat root  <prefix>/include/nlf
#     #include <nlf/UKF.h>              // prefixed   <prefix>/include
#     #include "rbpf/rbpf_core.hpp"
# and the optmath headers our public FilterMath.h pulls in resolve as
# <optmath/...> off <prefix>/include.

include(CMakeFindDependencyMacro)

# Eigen3 is PUBLIC on our interface: our headers are Eigen templates and expose
# Eigen types across the API boundary.
find_dependency(Eigen3 3.4)

# OpenMP is PUBLIC when the package was built with it (the particle filter and
# RBPF parallelise their propagation loops).
if(@OpenMP_CXX_FOUND@)
    find_dependency(OpenMP)
endif()

# OptMathKernels links Vulkan PRIVATE. It is a static library, so its private link
# dependencies still land on a consumer's link line and must be resolvable here --
# but only when the backend was actually built. Gate on NLF_VULKAN_ACTIVE (was the SDK
# found?) rather than ENABLE_VULKAN (was it requested?): the latter is ON by default
# and would demand the SDK from consumers of a package built without it.
if(@NLF_VULKAN_ACTIVE@)
    find_dependency(Vulkan)
endif()

# CUDA, when the package was built against it: our headers call into cudart
# directly under OPTMATH_USE_CUDA.
if(@NLF_HAS_CUDA@)
    find_dependency(CUDAToolkit)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/nlfTargets.cmake")

check_required_components(nlf)
